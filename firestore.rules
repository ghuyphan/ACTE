rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // Legacy room helpers kept while old room routes still exist in the app.
    function roomDoc(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId));
    }

    function roomExists(roomId) {
      return exists(/databases/$(database)/documents/rooms/$(roomId));
    }

    function isRoomOwner(roomId) {
      return signedIn() &&
        roomExists(roomId) &&
        roomDoc(roomId).data.ownerId == request.auth.uid;
    }

    function isRoomMember(roomId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid));
    }

    function roomInviteExists(roomId, inviteId) {
      return exists(/databases/$(database)/documents/rooms/$(roomId)/invites/$(inviteId));
    }

    function roomInviteIsActive(roomId, inviteId) {
      return roomInviteExists(roomId, inviteId) &&
        get(/databases/$(database)/documents/rooms/$(roomId)/invites/$(inviteId)).data.revokedAt == null;
    }

    function friendInviteDoc(inviteId) {
      return get(/databases/$(database)/documents/friendInvites/$(inviteId));
    }

    function friendInviteExists(inviteId) {
      return exists(/databases/$(database)/documents/friendInvites/$(inviteId));
    }

    function friendInviteAllowsLink(inviteId, userId, friendUid) {
      return signedIn() &&
        friendInviteExists(inviteId) &&
        friendInviteDoc(inviteId).data.revokedAt == null &&
        (friendInviteDoc(inviteId).data.acceptedByUid == null ||
          friendInviteDoc(inviteId).data.acceptedByUid == request.auth.uid) &&
        friendInviteDoc(inviteId).data.inviterUid != request.auth.uid &&
        (friendInviteDoc(inviteId).data.inviterUid == userId ||
          friendInviteDoc(inviteId).data.inviterUid == friendUid) &&
        (request.auth.uid == userId || request.auth.uid == friendUid);
    }

    function friendDocShapeIsValid(friendUid) {
      return request.resource.data.userId == friendUid &&
        (request.resource.data.displayNameSnapshot is string ||
          request.resource.data.displayNameSnapshot == null) &&
        (request.resource.data.photoURLSnapshot is string ||
          request.resource.data.photoURLSnapshot == null) &&
        request.resource.data.friendedAt is string &&
        (request.resource.data.lastSharedAt is string ||
          request.resource.data.lastSharedAt == null) &&
        request.resource.data.createdByInviteId is string;
    }

    function friendDocCreateIsValid(userId, friendUid) {
      return friendDocShapeIsValid(friendUid) &&
        request.resource.data.lastSharedAt == null &&
        friendInviteAllowsLink(request.resource.data.createdByInviteId, userId, friendUid);
    }

    function friendDocUpdateIsValid(userId) {
      return isSelf(userId) &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.displayNameSnapshot == resource.data.displayNameSnapshot &&
        request.resource.data.photoURLSnapshot == resource.data.photoURLSnapshot &&
        request.resource.data.friendedAt == resource.data.friendedAt &&
        request.resource.data.createdByInviteId == resource.data.createdByInviteId &&
        (request.resource.data.lastSharedAt is string ||
          request.resource.data.lastSharedAt == null);
    }

    function friendInviteCreateIsValid() {
      return signedIn() &&
        request.resource.data.inviterUid == request.auth.uid &&
        (request.resource.data.inviterDisplayNameSnapshot is string ||
          request.resource.data.inviterDisplayNameSnapshot == null) &&
        (request.resource.data.inviterPhotoURLSnapshot is string ||
          request.resource.data.inviterPhotoURLSnapshot == null) &&
        request.resource.data.token is string &&
        request.resource.data.createdAt is string &&
        request.resource.data.revokedAt == null &&
        request.resource.data.acceptedByUid == null &&
        request.resource.data.acceptedAt == null &&
        (request.resource.data.expiresAt is string ||
          request.resource.data.expiresAt == null);
    }

    function friendInviteImmutableFieldsUnchanged() {
      return request.resource.data.inviterUid == resource.data.inviterUid &&
        request.resource.data.inviterDisplayNameSnapshot == resource.data.inviterDisplayNameSnapshot &&
        request.resource.data.inviterPhotoURLSnapshot == resource.data.inviterPhotoURLSnapshot &&
        request.resource.data.token == resource.data.token &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.expiresAt == resource.data.expiresAt;
    }

    function friendInviteRevokeIsValid() {
      return signedIn() &&
        resource.data.inviterUid == request.auth.uid &&
        friendInviteImmutableFieldsUnchanged() &&
        request.resource.data.acceptedByUid == resource.data.acceptedByUid &&
        request.resource.data.acceptedAt == resource.data.acceptedAt &&
        request.resource.data.revokedAt is string;
    }

    function friendInviteAcceptIsValid() {
      return signedIn() &&
        resource.data.inviterUid != request.auth.uid &&
        resource.data.revokedAt == null &&
        resource.data.acceptedByUid == null &&
        friendInviteImmutableFieldsUnchanged() &&
        request.resource.data.revokedAt == resource.data.revokedAt &&
        request.resource.data.acceptedByUid == request.auth.uid &&
        request.resource.data.acceptedAt is string;
    }

    function sharedPostBaseIsValid() {
      return signedIn() &&
        request.resource.data.authorUid == request.auth.uid &&
        (request.resource.data.authorDisplayName is string ||
          request.resource.data.authorDisplayName == null) &&
        (request.resource.data.authorPhotoURLSnapshot is string ||
          request.resource.data.authorPhotoURLSnapshot == null) &&
        request.resource.data.audienceUserIds is list &&
        request.auth.uid in request.resource.data.audienceUserIds &&
        request.resource.data.audienceUserIds.size() > 1 &&
        request.resource.data.audienceUserIds.size() <= 25 &&
        request.resource.data.type in ['text', 'photo'] &&
        request.resource.data.text is string &&
        (request.resource.data.photoRemoteBase64 is string ||
          request.resource.data.photoRemoteBase64 == null) &&
        (request.resource.data.placeName is string ||
          request.resource.data.placeName == null) &&
        (request.resource.data.sourceNoteId is string ||
          request.resource.data.sourceNoteId == null) &&
        request.resource.data.createdAt is string &&
        (request.resource.data.updatedAt is string ||
          request.resource.data.updatedAt == null);
    }

    match /users/{userId} {
      allow get: if signedIn();
      allow list: if false;
      allow create, update, delete: if isSelf(userId);

      match /notes/{noteId} {
        allow read, write: if isSelf(userId);
      }

      match /friends/{friendUid} {
        allow read: if isSelf(userId);
        allow create: if friendDocCreateIsValid(userId, friendUid);
        allow update: if friendDocUpdateIsValid(userId);
        allow delete: if signedIn() &&
          (request.auth.uid == userId || request.auth.uid == friendUid);
      }

      // Legacy room membership index preserved during migration.
      match /roomMemberships/{roomId} {
        allow read: if isSelf(userId);

        allow create, update: if isSelf(userId) &&
          request.resource.data.roomId == roomId &&
          exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(userId));

        allow delete: if isSelf(userId) || isRoomOwner(roomId);
      }
    }

    match /friendInvites/{inviteId} {
      allow get: if signedIn() && (
        resource.data.inviterUid == request.auth.uid ||
        (
          resource.data.revokedAt == null &&
          (resource.data.acceptedByUid == null ||
            resource.data.acceptedByUid == request.auth.uid)
        )
      );

      allow list: if signedIn() && (
        resource.data.inviterUid == request.auth.uid ||
        (
          request.query.limit != null &&
          request.query.limit <= 1 &&
          resource.data.revokedAt == null &&
          (resource.data.acceptedByUid == null ||
            resource.data.acceptedByUid == request.auth.uid)
        )
      );

      allow create: if friendInviteCreateIsValid();
      allow update: if friendInviteRevokeIsValid() || friendInviteAcceptIsValid();
      allow delete: if false;
    }

    match /sharedPosts/{postId} {
      allow get, list: if signedIn() &&
        (resource.data.authorUid == request.auth.uid ||
          request.auth.uid in resource.data.audienceUserIds);

      allow create: if sharedPostBaseIsValid();

      allow update: if signedIn() &&
        resource.data.authorUid == request.auth.uid &&
        sharedPostBaseIsValid() &&
        request.resource.data.authorUid == resource.data.authorUid &&
        request.resource.data.audienceUserIds == resource.data.audienceUserIds &&
        request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if signedIn() && resource.data.authorUid == request.auth.uid;
    }

    // Legacy rooms rules kept temporarily so old routes do not break during migration.
    match /rooms/{roomId} {
      allow create: if signedIn() &&
        request.resource.data.ownerId == request.auth.uid;

      allow read: if isRoomMember(roomId);
      allow update, delete: if isRoomOwner(roomId);

      match /members/{memberId} {
        allow read: if isRoomMember(roomId);

        allow create: if signedIn() &&
          memberId == request.auth.uid &&
          request.resource.data.roomId == roomId &&
          request.resource.data.userId == request.auth.uid &&
          (
            (
              request.resource.data.role == 'owner' &&
              isRoomOwner(roomId) &&
              request.resource.data.joinedViaInviteId == null
            ) ||
            (
              request.resource.data.role == 'member' &&
              request.resource.data.joinedViaInviteId is string &&
              roomInviteIsActive(roomId, request.resource.data.joinedViaInviteId)
            )
          );

        allow update: if signedIn() &&
          memberId == request.auth.uid &&
          request.resource.data.roomId == resource.data.roomId &&
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.displayNameSnapshot == resource.data.displayNameSnapshot &&
          request.resource.data.photoURLSnapshot == resource.data.photoURLSnapshot &&
          request.resource.data.joinedAt == resource.data.joinedAt &&
          request.resource.data.joinedViaInviteId == resource.data.joinedViaInviteId;

        allow delete: if isRoomOwner(roomId) || (signedIn() && memberId == request.auth.uid);
      }

      match /posts/{postId} {
        allow read: if isRoomMember(roomId);

        allow create: if isRoomMember(roomId) &&
          request.resource.data.roomId == roomId &&
          request.resource.data.authorId == request.auth.uid;

        allow update, delete: if isRoomOwner(roomId) || (
          isRoomMember(roomId) &&
          resource.data.authorId == request.auth.uid
        );
      }

      match /invites/{inviteId} {
        allow read, create, update, delete: if isRoomOwner(roomId);
      }
    }
  }
}
