<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/noto_widget_outer_surface"
    android:clipToPadding="false">

    <FrameLayout
        android:id="@+id/widget_card_shell"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/widget_shell_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="fitXY" />

        <RelativeLayout
            android:id="@+id/widget_card_inner"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/widget_inner_background"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitXY" />

            <ImageView
                android:id="@+id/widget_text_background_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/widget_photo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="false"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/widget_photo_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/widget_sticker_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/widget_doodle_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/widget_location_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="14dp"
                android:background="@drawable/noto_widget_badge_light"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="13dp"
                android:paddingTop="7dp"
                android:paddingRight="14dp"
                android:paddingBottom="7dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/widget_location_icon"
                    android:layout_width="11dp"
                    android:layout_height="11dp"
                    android:contentDescription="@null"
                    android:src="@drawable/noto_widget_pin_icon" />

                <TextView
                    android:id="@+id/widget_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:maxWidth="132dp"
                    android:paddingLeft="5dp"
                    android:textColor="#7A6A58"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_top_right_stack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="12dp"
                android:gravity="end"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/widget_live_photo_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/noto_widget_overlay_chip_dark"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingLeft="8dp"
                    android:paddingTop="5dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="5dp"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/widget_live_photo_icon"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:contentDescription="@null"
                        android:src="@drawable/noto_widget_live_photo_icon" />
                </LinearLayout>

                <TextView
                    android:id="@+id/widget_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/noto_widget_badge_light"
                    android:ellipsize="end"
                    android:fontFamily="@font/xml_noto_sans"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:paddingLeft="11dp"
                    android:paddingTop="6dp"
                    android:paddingRight="11dp"
                    android:paddingBottom="6dp"
                    android:textColor="#7A6A58"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/widget_text_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@id/widget_location_chip"
                android:layout_above="@id/widget_bottom_content"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/widget_idle_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="3dp"
                    android:maxLines="4"
                    android:paddingLeft="26dp"
                    android:paddingRight="26dp"
                    android:textColor="#FFF7E8"
                    android:textSize="15sp"
                    android:textStyle="italic"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/widget_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:letterSpacing="-0.03"
                    android:lineSpacingExtra="3dp"
                    android:maxLines="4"
                    android:paddingLeft="20dp"
                    android:paddingRight="20dp"
                    android:textColor="#2B2621"
                    android:textSize="17sp" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/widget_bottom_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_photo_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-black"
                    android:includeFontPadding="false"
                    android:letterSpacing="-0.03"
                    android:lineSpacingExtra="1dp"
                    android:maxLines="2"
                    android:maxWidth="162dp"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="8"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/widget_author_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/noto_widget_badge_light"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingLeft="7dp"
                    android:paddingTop="5dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="5dp"
                    android:visibility="gone">

                    <FrameLayout
                        android:layout_width="18dp"
                        android:layout_height="18dp">

                        <ImageView
                            android:id="@+id/widget_author_avatar"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/widget_author_initials"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:fontFamily="@font/xml_noto_sans"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:textColor="#2B2621"
                            android:textSize="9sp"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/widget_author_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/xml_noto_sans"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:maxWidth="96dp"
                        android:paddingLeft="6dp"
                        android:textColor="#2B2621"
                        android:textSize="10sp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

        </RelativeLayout>
    </FrameLayout>
</RelativeLayout>
